# Math-Tree env（実値は .env.local、コミット禁止）
DATABASE_URL=postgres://...                       # Neon
# フロント公開鍵は Vite が client へ露出するため VITE_ 接頭辞が必須（O22 連携 UI / authProvider）
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# 匿名ゲスト自前署名トークンの秘密鍵（HS256, O22/O58）。十分長いランダム文字列を生成（例: openssl rand -base64 48）
GUEST_TOKEN_SECRET=
ANTHROPIC_API_KEY=sk-ant-...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# tip-jar UI を出すフラグ。Stripe 配線時に true（ゲスト専用 MVP では未設定=非表示）
VITE_ENABLE_TIPJAR=
TURNSTILE_SECRET_KEY=...
# コスト単価（§4.6.2、ハードコード禁止）
COST_ANTHROPIC_PER_1K_INPUT_TOKENS=0.003
COST_ANTHROPIC_PER_1K_OUTPUT_TOKENS=0.015
CRON_SECRET=
CURRICULUM_MODELS=
